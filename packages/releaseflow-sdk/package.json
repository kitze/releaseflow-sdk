{
  "name": "releaseflow-sdk",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the ReleaseFlow API",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "openapi-ts",
    "fix-imports": "node fix-imports.mjs",
    "build": "pnpm generate && pnpm fix-imports && tsc",
    "clean": "rm -rf dist src/client",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "releaseflow",
    "api",
    "sdk",
    "typescript",
    "sparkle",
    "electron",
    "auto-updates",
    "releases"
  ],
  "author": "Kitze",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kitze/releaseflow-sdk.git",
    "directory": "packages/releaseflow-sdk"
  },
  "bugs": {
    "url": "https://github.com/kitze/releaseflow-sdk/issues"
  },
  "homepage": "https://github.com/kitze/releaseflow-sdk#readme",
  "devDependencies": {
    "@hey-api/openapi-ts": "0.97.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
