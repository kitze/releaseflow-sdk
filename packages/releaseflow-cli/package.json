{
  "name": "releaseflow-cli",
  "version": "0.1.0",
  "description": "CLI for the ReleaseFlow API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "releaseflow": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsx src/index.ts",
    "postbuild": "chmod +x dist/index.js"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "releaseflow-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "author": "Kitze",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kitze/releaseflow-sdk.git",
    "directory": "packages/releaseflow-cli"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
